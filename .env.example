# Required: at least one provider key
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: override default model
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ⚠️ Security Warning:
# If deploying publicly (e.g. Vercel), do NOT set API keys here.
# Let users provide their own key via the UI instead.
# Setting keys in env vars on a public deployment shares your key with all users.
